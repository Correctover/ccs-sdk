# CCS Governance Configuration
# Copy this file to .env and adjust values as needed

# Governance evaluation timeout in milliseconds (default: 50)
# CCS_TIMEOUT_MS=50

# Enable/disable audit logging (default: true)
# CCS_AUDIT_LOG=true

# Maximum tool input size in bytes (default: 1000000 = 1MB)
# CCS_MAX_TOOL_INPUT_SIZE=1000000

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# CCS_LOG_LEVEL=INFO
